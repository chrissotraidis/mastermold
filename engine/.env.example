# Copy to engine/.env (gitignored) and fill in. Keys live ONLY here, never committed.
# The dashboard never reads this file; it only reads the JSON bundles in engine/out/.

# Provider for both tiers (config.yml sets the model ids). OpenRouter is the default.
OPENROUTER_API_KEY=

# Anthropic remains supported if config.yml provider/models are switched.
ANTHROPIC_API_KEY=

# Optional: paid market-data source if yfinance's free tier becomes unreliable.
# The dataflows vendor layer makes this a config flip, not a rewrite (see Risks).
# ALPHAVANTAGE_API_KEY=

# Optional override for the data-drop directory the dashboard ingests from.
# Defaults to engine/out next to the package.
# ENGINE_OUT_DIR=
