# Public-safe example values only. Copy to .env.local for local use.

# The app runs on port 4002 (pinned in the dev/start scripts) so bin/daily-run,
# the launchd templates, and integration tests line up out of the box. To move
# it, set PORT in your shell (not here — Next binds before env files load) and
# export MASTERMOLD_URL for bin/daily-run.
MASTERMOLD_DB=.data/mastermold.db
AUTOPILOT_DB=.data/autopilot.db.json
ENGINE_OUT_DIR=engine/out

# Optional model/provider keys. Leave blank unless configuring locally.
# Three separate surfaces read LLM keys — set the one(s) you want:
#   1. Chat (/api/chat): ANTHROPIC_API_KEY or OPENROUTER_API_KEY or
#      OPENAI_API_KEY below. Restart the server after changing them.
#   2. Today-page play refiner + autopilot Analyst: OPENROUTER_API_KEY below.
#      (Without it the Analyst falls back to the built-in rule-based review.)
#   3. Python briefing engine: its own keys in engine/.env (see engine/README.md).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional market/provider settings.
SOLANA_RPC_URL=
HELIUS_ENABLED=false
HELIUS_API_KEY=

# Optional wallet discovery: free API key from solanatracker.io unlocks the
# real profitable-wallet leaderboard (trap-filtered) for Smart Wallets
# suggestions. Without it, discovery falls back to trending-pool activity
# leads that carry no PnL history.
SOLANATRACKER_API_KEY=

# Optional Monarch Money import (MCP). Set a command that speaks MCP over
# stdio, or an HTTP URL; leave blank to hide the panel's connection state.
MONARCH_MCP_COMMAND=
MONARCH_MCP_URL=

# Optional operator notifications (fills, halts, daemon lifecycle, analyst
# changes). Telegram: create a bot with @BotFather, message it once, read your
# chat id from getUpdates. Desktop uses the macOS notification center.
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_DESKTOP=false
