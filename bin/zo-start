#!/usr/bin/env bash
# bin/zo-start — what a Zo Service / systemd unit / @reboot cron runs.
#
# A thin, idempotent wrapper over production bin/up: installs dependencies and
# builds only when missing, then hands off to the real supervisor (web app +
# autopilot daemon, crash restarts, log trimming). Kept as its own entrypoint
# so the Service command never has to change when bin/up grows.
#
# Binding stays 127.0.0.1 (bin/up's default) — this app has NO authentication.
# Reach it over an SSH tunnel or Tailscale; only set MASTERMOLD_BIND=0.0.0.0
# behind an authenticating reverse proxy, knowingly.
#
# See docs/ZO-MIGRATION.md for the full cutover checklist.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

[ -d node_modules ] || npm install
[ -f .next/standalone/server.js ] || npm run build

MASTERMOLD_WEB=prod exec bin/up
